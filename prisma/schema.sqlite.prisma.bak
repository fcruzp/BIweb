generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Auth Models
// ============================================

model User {
  id             String         @id @default(cuid())
  supabaseId     String         @unique // Maps to auth.uid() in Supabase Auth
  email          String         @unique
  name           String?
  avatarUrl      String?
  company        String?
  phone          String?
  role           String         @default("user") // admin, user
  country        String?        // For ITBIS detection (e.g., "DO" for Dominican Republic)
  taxId          String?        // NCF / RNC for Dominican companies
  preferredLang  String         @default("es") // es, en
  openRouterKey  String?        // User's own OpenRouter API key

  // Relationships
  dataSources    DataSource[]
  chatSessions   ChatSession[]
  dashboards     Dashboard[]
  subscription   Subscription?
  usageEvents    UsageEvent[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  plan                  String    @default("free") // free, supporter, starter, pro, business
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  status                String    @default("active") // active, past_due, canceled, incomplete
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean   @default(false)

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model UsageEvent {
  id            String    @id @default(cuid())
  userId        String
  eventType     String    // query_executed, file_uploaded, dashboard_created, etc.
  metadata      String    @default("{}") // JSON string with event details

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
}

// ============================================
// Data Source Models
// ============================================

model DataSource {
  id           String         @id @default(cuid())
  userId       String?        // Multi-tenant: owner (nullable until Phase 2 Auth)
  name         String
  fileName     String
  fileSize     Int
  filePath     String
  fileType     String         @default("sqlite")
  status       String         @default("uploaded") // uploaded, analyzing, ready, error
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  schemas      SourceSchema[]
  contexts     SourceContext[]
  queries      QueryHistory[]
  sessions     ChatSession[]

  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SourceSchema {
  id           String     @id @default(cuid())
  dataSourceId String
  tableName    String
  columns      String     // JSON string of column definitions
  rowCount     Int        @default(0)
  sampleData   String     // JSON string of sample rows
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
}

model SourceContext {
  id               String     @id @default(cuid())
  dataSourceId     String
  semanticContext  String     // Rich semantic metadata generated by AI
  businessGlossary String     // JSON string of business terms
  relationships    String     // JSON string of inferred relationships
  summary          String     // Human-readable summary
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  dataSource       DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
}

// ============================================
// Chat Models
// ============================================

model ChatSession {
  id           String         @id @default(cuid())
  userId       String?        // Multi-tenant: owner (nullable until Phase 2 Auth)
  dataSourceId String
  title        String         @default("New Chat")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     ChatMessage[]
  queries      QueryHistory[]

  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataSource   DataSource     @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id            String      @id @default(cuid())
  sessionId     String
  role          String      // user, assistant, system
  content       String
  sqlQuery      String?     // If assistant generated SQL
  queryResult   String?     // JSON string of query results
  visualization String?     // JSON string of visualization config
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ============================================
// Query History
// ============================================

model QueryHistory {
  id            String        @id @default(cuid())
  dataSourceId  String
  sessionId     String?
  naturalQuery  String        // The user's natural language question
  sqlQuery      String        // The generated SQL
  resultData    String        // JSON string of results
  rowCount      Int           @default(0)
  executionTime Int           @default(0) // milliseconds
  status        String        @default("success") // success, error
  errorMessage  String?
  createdAt     DateTime      @default(now())
  dataSource    DataSource    @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  session       ChatSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
}

// ============================================
// Dashboard Models
// ============================================

model Dashboard {
  id          String           @id @default(cuid())
  userId      String?          // Multi-tenant: owner (nullable until Phase 2 Auth)
  name        String
  description String?
  layout      String           // JSON string of layout config
  widgets     DashboardWidget[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DashboardWidget {
  id            String    @id @default(cuid())
  dashboardId   String
  title         String
  widgetType    String    // chart, table, metric, text, map
  dataSourceId  String?
  sqlQuery      String?
  visualization String?   // JSON string of visualization config
  config        String    // JSON string of widget config
  positionX     Int       @default(0)
  positionY     Int       @default(0)
  width         Int       @default(6)
  height        Int       @default(4)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  dashboard     Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
}
