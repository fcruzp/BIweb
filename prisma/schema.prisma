generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DataSource {
  id           String         @id @default(cuid())
  name         String
  fileName     String
  fileSize     Int
  filePath     String
  fileType     String         @default("sqlite")
  status       String         @default("uploaded") // uploaded, analyzing, ready, error
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  schemas      SourceSchema[]
  contexts     SourceContext[]
  queries      QueryHistory[]
}

model SourceSchema {
  id           String     @id @default(cuid())
  dataSourceId String
  tableName    String
  columns      String     // JSON string of column definitions
  rowCount     Int        @default(0)
  sampleData   String     // JSON string of sample rows
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([dataSourceId])
}

model SourceContext {
  id               String     @id @default(cuid())
  dataSourceId     String
  semanticContext  String     // Rich semantic metadata generated by AI
  businessGlossary String     // JSON string of business terms
  relationships    String     // JSON string of inferred relationships
  summary          String     // Human-readable summary
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  dataSource       DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([dataSourceId])
}

model ChatSession {
  id           String         @id @default(cuid())
  dataSourceId String
  title        String         @default("New Chat")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     ChatMessage[]
  queries      QueryHistory[]

  @@index([dataSourceId])
}

model ChatMessage {
  id            String      @id @default(cuid())
  sessionId     String
  role          String      // user, assistant, system
  content       String
  sqlQuery      String?     // If assistant generated SQL
  queryResult   String?     // JSON string of query results
  visualization String?     // JSON string of visualization config
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model QueryHistory {
  id            String        @id @default(cuid())
  dataSourceId  String
  sessionId     String?
  naturalQuery  String        // The user's natural language question
  sqlQuery      String        // The generated SQL
  resultData    String        // JSON string of results
  rowCount      Int           @default(0)
  executionTime Int           @default(0) // milliseconds
  status        String        @default("success") // success, error
  errorMessage  String?
  createdAt     DateTime      @default(now())
  dataSource    DataSource    @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  session       ChatSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([dataSourceId])
  @@index([createdAt])
}

model Dashboard {
  id          String           @id @default(cuid())
  name        String
  description String?
  layout      String           // JSON string of layout config
  widgets     DashboardWidget[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model DashboardWidget {
  id            String    @id @default(cuid())
  dashboardId   String
  title         String
  widgetType    String    // chart, table, metric, text
  dataSourceId  String?
  sqlQuery      String?
  visualization String?   // JSON string of visualization config
  config        String    // JSON string of widget config
  positionX     Int       @default(0)
  positionY     Int       @default(0)
  width         Int       @default(6)
  height        Int       @default(4)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  dashboard     Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
}
